# ─────────────────────────────────────────────────────────────────────────────
#  EidCard — Environment Variables
#  Copy this file to .env.local for local dev (NEVER commit .env.local)
#  Set all variables in Vercel → Settings → Environment Variables for production
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (ensure IP 0.0.0.0/0 is whitelisted for Vercel)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── NextAuth ──────────────────────────────────────────────────────────────────
# MUST match your production domain exactly — no trailing slash
NEXTAUTH_URL=https://salami-saas.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here

# ── Google OAuth (optional — for "Continue with Google") ─────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App URL (used in OG tags & card share URLs) ───────────────────────────────
NEXT_PUBLIC_APP_URL=https://salami-saas.vercel.app

# ── bKash ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BKASH_NUMBER=01XXXXXXXXX

# ── Rate limiting (Upstash Redis — optional) ──────────────────────────────────
# Get from https://upstash.com — leave blank to skip rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (optional — for password reset emails) ──────────────────────────────
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=EidCard <noreply@salami-saas.vercel.app>
