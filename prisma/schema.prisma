generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum PlanType {
  ONE_TIME
  PREMIUM
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  EDIT_REQUEST
  TAKE_DOWN
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  passwordHash  String?
  name          String?
  phone         String?
  image         String?
  role          UserRole  @default(USER)
  plan          PlanType  @default(ONE_TIME)
  planExpiresAt DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  cards    Card[]
  requests UserRequest[]
  notifications Notification[]
  viewedAnalytics Analytics[]
  paymentRequests PaymentRequest[]
  reviewedPayments  PaymentRequest[] @relation("PaymentReviewedBy")
  reviewedRequests  UserRequest[]    @relation("ReviewedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Card {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  slug           String   @unique
  eidType        String
  theme          String
  audio          String
  phone          String
  customMessage  String
  recipientName  String?
  isPublished    Boolean  @default(false)
  isActive       Boolean  @default(true)
  viewCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  analytics Analytics[]

  @@map("cards")
}

model UserRequest {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @db.ObjectId
  cardId      String?       @db.ObjectId
  type        RequestType
  status      RequestStatus @default(PENDING)
  details     String?
  reviewedBy  String?       @db.ObjectId
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@map("user_requests")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Analytics {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cardId    String   @db.ObjectId
  userId    String   @db.ObjectId
  ip        String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  viewedAt  DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("analytics")
}

model PaymentRequest {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  userId          String        @db.ObjectId
  plan            PlanType
  amount          Float
  transactionId   String        @unique
  senderNumber    String
  status          RequestStatus @default(PENDING)
  adminNote       String?
  reviewedBy      String?       @db.ObjectId
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("PaymentReviewedBy", fields: [reviewedBy], references: [id])

  @@map("payment_requests")
}

